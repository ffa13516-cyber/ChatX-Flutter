import 'dart:convert';
import 'dart:typed_data';
import 'package:archive/archive.dart';
import '../models/sticker_pack_dto.dart';

class StickerZipImporter {
  /// 🔥 فك الـ ZIP وتحويله لـ StickerPackDTO
  static Future<StickerPackDTO?> import(Uint8List zipBytes) async {
    try {
      final archive = ZipDecoder().decodeBytes(zipBytes);

      /// 🧠 نخزن كل الملفات (اسم → bytes)
      final Map<String, Uint8List> files = {};

      for (final file in archive) {
        if (file.isFile) {
          files[file.name] = Uint8List.fromList(file.content);
        }
      }

      /// 🔎 نجيب JSON
      Map<String, dynamic>? jsonData;

      for (final entry in files.entries) {
        if (entry.key.endsWith('.json')) {
          final content = utf8.decode(entry.value);
          jsonData = json.decode(content);
          break;
        }
      }

      if (jsonData == null) {
        print("❌ No JSON file found in ZIP");
        return null;
      }

      /// 🔥 تحويل JSON → DTO
      final dto = StickerPackDTO.fromJson(jsonData);

      /// 🔥 ربط الصور بالـ stickers
      for (final sticker in dto.stickers) {
        final fileName = sticker.file;

        if (files.containsKey(fileName)) {
          sticker.bytes = files[fileName];
        } else {
          print("⚠️ Missing sticker file: $fileName");
        }
      }

      return dto;
    } catch (e) {
      print("❌ STICKER ZIP IMPORT ERROR: $e");
      return null;
    }
  }
}
